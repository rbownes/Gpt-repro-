graph TD
    X["x &lt;sub&gt;in&lt;/sub&gt;"]
    SK_OUT["U-Net skip<br/>from layer (n−1−i)<br/>(only when i ≥ n/2)"]
    SK_OUT -. "+" .-> X

    X --> RMS1[RMSNorm]
    RMS1 --> Q[Linear → Q]
    RMS1 --> K[Linear → K]
    RMS1 --> V[Linear → V]
    Q --> QKN1[RMSNorm Q]
    K --> QKN2[RMSNorm K]
    QKN1 --> ROPE_Q[RoPE]
    QKN2 --> ROPE_K[RoPE]
    ROPE_Q --> ATTN[SDPA causal]
    ROPE_K --> ATTN
    V --> ATTN
    ATTN --> PROJ["Linear<br/>(zero-init weights)"]
    PROJ --> R1["+ residual"]
    X --> R1

    R1 --> RMS2[RMSNorm]
    RMS2 --> FC1[Linear 768 → 3072]
    FC1 --> RELU2["ReLU²(x) = max(0,x)²"]
    RELU2 --> FC2["Linear 3072 → 768<br/>(zero-init weights)"]
    FC2 --> R2["+ residual"]
    R1 --> R2
    R2 --> XOUT["x &lt;sub&gt;out&lt;/sub&gt;"]

    R2 -. "→ U-Net skip<br/>(only when i &lt; n/2)" .-> SK_IN[("LIFO stack")]

    classDef norm fill:#e1f5fe,stroke:#0277bd
    classDef linear fill:#f3e5f5,stroke:#6a1b9a
    classDef act fill:#fff3e0,stroke:#e65100
    classDef attn fill:#fce4ec,stroke:#c2185b
    classDef residual fill:#e8f5e9,stroke:#2e7d32
    classDef rope fill:#ffebee,stroke:#c62828
    classDef skip fill:#fff9c4,stroke:#f57f17
    classDef zero fill:#ede7f6,stroke:#5e35b1
    class RMS1,RMS2,QKN1,QKN2 norm
    class Q,K,V,FC1 linear
    class PROJ,FC2 zero
    class RELU2 act
    class ATTN attn
    class R1,R2 residual
    class ROPE_Q,ROPE_K rope
    class SK_IN,SK_OUT skip
